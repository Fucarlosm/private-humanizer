{
  "manifest_version": 2,
  "id": "org.maibot.private-humanizer",
  "version": "0.1.0",
  "name": "麦麦私聊拟人化增强",
  "description": "为指定 MaiBot 私聊注入时间感、对象画像和事实边界，减少无证据编造与过度小说化回复。",
  "author": {
    "name": "Fucarlosm",
    "url": "https://github.com/Fucarlosm"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Fucarlosm/private-humanizer",
    "documentation": "https://github.com/Fucarlosm/private-humanizer#readme"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "plugin_type": "extension",
  "display": {
    "icon": {
      "type": "lucide",
      "value": "shield-check"
    }
  },
  "capabilities": [
    "trigger_proactive",
    "maisaka.proactive.trigger"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  }
}
